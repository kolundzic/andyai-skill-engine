{
  "id": "andyai.minimal.status",
  "version": "0.4.0",
  "title": "Minimal Status Skill",
  "purpose": "Turn simple execution state into a concise structured summary.",
  "inputs": [
    {
      "name": "state",
      "type": "string"
    },
    {
      "name": "details",
      "type": "object"
    }
  ],
  "outputs": [
    {
      "name": "summary",
      "type": "string"
    },
    {
      "name": "severity",
      "type": "string"
    }
  ],
  "constraints": [
    "must be concise",
    "must not invent execution facts"
  ],
  "compatibility": [
    "copilot-export",
    "internal-ui"
  ],
  "trust": {
    "evidence_required": false,
    "safe_for_preview": true
  }
}